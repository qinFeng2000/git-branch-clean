{
  "name": "git-branch-clean",
  "displayName": "Git Branch Clean",
  "description": "检查并清理长期未处理的本地 Git 分支。",
  "version": "0.1.4",
  "publisher": "flsh",
  "license": "GPL-3.0-only",
  "repository": "https://github.com/qinFeng2000/git-branch-clean",
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:gitBranchCleanup.checkStaleBranches"
  ],
  "main": "./dist/src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "gitBranchCleanup.checkStaleBranches",
        "title": "Git Branch Clean: 检查过期分支",
        "category": "Git Branch Clean"
      }
    ],
    "keybindings": [
      {
        "command": "gitBranchCleanup.checkStaleBranches",
        "key": "ctrl+alt+b",
        "mac": "cmd+alt+b",
        "when": "editorTextFocus && workspaceFolderCount > 0"
      }
    ],
    "configuration": {
      "title": "Git Branch Clean",
      "properties": {
        "gitBranchCleanup.mainBranch": {
          "type": "string",
          "default": "main,master",
          "description": "用于判断分支是否已合并的主分支名称，多个分支用英文逗号分隔。"
        },
        "gitBranchCleanup.staleHours": {
          "type": "number",
          "default": 720,
          "minimum": 1,
          "description": "分支最后提交达到或超过多少小时后提示清理。"
        },
        "gitBranchCleanup.includeBranchPatterns": {
          "type": "string",
          "default": "*",
          "description": "要检查的本地分支模式，多个模式用英文逗号分隔，支持 * 通配符，例如 chore/*。"
        },
        "gitBranchCleanup.excludeBranchPatterns": {
          "type": "string",
          "default": "",
          "description": "要排除的本地分支模式，多个模式用英文逗号分隔，支持 * 通配符，例如 release/*。"
        },
        "gitBranchCleanup.fetchRemoteBeforeScan": {
          "type": "boolean",
          "default": false,
          "description": "检查前是否执行 git fetch --all --prune，并使用远程主分支引用参与已合并判断。"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "pnpm run compile && node --test dist/test/*.js",
    "package:vsix": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.17.10",
    "@types/vscode": "1.90.0",
    "typescript": "^5.7.2",
    "vsce": "^2.15.0"
  }
}
